                                    </td>
                                    <td style="width: 20%" align="center">
                                        <span id="countDown"></span>
                                    </td>
                                    <td style="width: 20%" align="center">
                                        <div style="position: relative; top: 0%; margin: 0 auto; padding-right: 0px;">
                                            <span id="SpanClock">Clock</span>
                                        </div>
                                    </td>
