                                            <object style="width: 100%; height: 100%;" z-index="-1">
                                                <param name="movie" value="<%= MyFunction() %>" />
                                                <embed src="<%= MyFunction() %>" width="100%" height="100%"></embed>
                                            </object>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="width: 100%; border: #000099 3px solid;">
                            <marquee behavior="alternate" scrollamount="1" style="font-size: small; font-weight: bolder;
                                color: Blue" onmouseover="this.stop()" onmouseout="this.start()">
                                Please Check Out Your Attendance Status Regularly. After 25<sup>th</sup> HR Will
                                Not Be Responsible For Any Changes...</marquee>
                           <hr style="padding: 0px" />
                            <marquee behavior="alternate" scrollamount="1" style="font-size: small; font-weight: bolder;
                                color: Blue" onmouseover="this.stop()" onmouseout="this.start()">
                                <img src="http://192.168.165.22:100/Images/New.jpg" />
                                Feature : Now Employee Can Change Their Photo. Just Click On Your Photo & Follow Instruction.</marquee>
                        </td>
                    </tr>
                    <tr>
                        <td style="width: 100%; border: #000099 3px solid; padding: 5px;">
