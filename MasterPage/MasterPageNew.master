                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <script language="javascript" type="text/javascript">
        window.moveTo(0,0);
        if (document.all) {top.window.resizeTo(screen.availWidth,screen.availHeight);}
        else if (document.layers||document.getElementById) {
        if (top.window.outerHeight<screen.availHeight||top.window.outerWidth<screen.availWidth){top.window.outerHeight = screen.availHeight;top.window.outerWidth = screen.availWidth;}}
        window.onload = function() { changeInputs();updateClock(); setInterval('updateClock()', 1000 ) }
       
        </script>

        <script language="JavaScript" type="Text/JavaScript">
//Made by 1st JavaScript Editor
//http://www.yaldex.com
//Come and get more (free) products

var fifteenth;var sixteenth;var seventeenth;var eighteenth=17;var nineteenth=1.2;var twentieth=3;var first2;
function second2(third2) { 
seventeenth=eval("document.getElementById('"+third2+"')");fifteenth=seventeenth.childNodes[0].nodeValue;fourth2();}
function fourth2() {
if (eighteenth<=180) {
if (twentieth<0) {sixteenth=fifteenth+'\xa0';}
else if (twentieth>0) {sixteenth='\xa0'+fifteenth};seventeenth.childNodes[0].nodeValue=sixteenth; twentieth=twentieth*-1;eighteenth=eighteenth*nineteenth;first2=setTimeout('fourth2()',eighteenth)	;}else {clearTimeout(first2);eighteenth=18;seventeenth.childNodes[0].nodeValue=fifteenth; }}
function fifth2() { 
clearTimeout(first2);eighteenth=22;seventeenth.childNodes[0].nodeValue=fifteenth; }  

        </script>

        <script language="javascript" type="text/javascript">
               document.getElementById('<%= hfBrowserWidth.ClientID %>').value = GetBrowserWidth() 
        </script>

