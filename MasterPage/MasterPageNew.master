    <title>OKS - Leave Management System</title>
    <style type="text/css">
#SpanClock { font-family: Tahoma, Helvetica, sans-serif; 
font-size: 13Px; 
color: Black;
 

 padding: 4px; }

#countDown { font-family: Tahoma; 
font-size: 13Px; 
color: Black;
 
  }
 
 #fixed1 { position: fixed; top: 5px; right : 5px;  } 
</style>

    <script type="text/javascript" language="javascript">
       
var min = 12;
var max = 25;
var s = 0;


function increaseFontSize()
{
   var p = document.getElementsByTagName('body');
   for(i = 0; i < p.length; i ++ )
   {
      if(p[i].style.fontSize)
      {
         s = parseInt(p[i].style.fontSize.replace("px", ""));
      }
      else
      {
         s = 12;
      }
      if(s != max)
      {
         s += 1;
      }
      p[i].style.fontSize = s + "px"      
   }
}
function decreaseFontSize()
{
   var p = document.getElementsByTagName('body');
   for(i = 0; i < p.length; i ++ )
   {
      if(p[i].style.fontSize)
      {
         s = parseInt(p[i].style.fontSize.replace("px", ""));
      }
      else
      {
         s = 12;
      }
      if(s != min)
      {
         s -= 1;
      }
      p[i].style.fontSize = s + "px"
   }
}





    </script>

    <script language="javascript" type="text/javascript">
        function changeInputs()      
       {
        if (document.all) 
            {
                for (formIdx=0; formIdx<document.forms.length; formIdx++) 
                    {
                        var theForm = document.forms[formIdx];
                        for (elementIdx=0; elementIdx<theForm.elements.length; elementIdx++) 
                            {
                                   window.status += theForm[elementIdx].type;
                                    if(theForm[elementIdx].type == "select-one") 
                                     theForm[elementIdx].className = 'text';
                                    if(theForm[elementIdx].type == "text") 
                                     theForm[elementIdx].className = 'text';
                                    if(theForm[elementIdx].type == "file") 
                                     theForm[elementIdx].className = 'file';
                                    else
                                     theForm[elementIdx].className = 'button';
                            }
                    }
            }
       }
       
       
       
       
function init ( )
{
  timeDisplay = document.createTextNode ( "" );
  document.getElementById("clock").appendChild ( timeDisplay );
}

function updateClock ( )
{
  var currentTime = new Date ( );

  var currentHours = currentTime.getHours ( );
  var currentMinutes = currentTime.getMinutes ( );
  var currentSeconds = currentTime.getSeconds ( );

  // Pad the minutes and seconds with leading zeros, if required
  currentMinutes = ( currentMinutes < 10 ? "0" : "" ) + currentMinutes;
  currentSeconds = ( currentSeconds < 10 ? "0" : "" ) + currentSeconds;

  // Choose either "AM" or "PM" as appropriate
  var timeOfDay = ( currentHours < 12 ) ? "AM" : "PM";

  // Convert the hours component to 12-hour format if needed
  currentHours = ( currentHours > 12 ) ? currentHours - 12 : currentHours;

  // Convert an hours component of "0" to "12"
  currentHours = ( currentHours == 0 ) ? 12 : currentHours;

  // Compose the string for display
  var currentTimeString = currentHours + ":" + currentMinutes + ":" + currentSeconds + " " + timeOfDay;

  // Update the time display
  
  document.getElementById('SpanClock').firstChild.nodeValue = currentTimeString;
}





       
    </script>

    <script language="javascript" type="text/javascript">
    var timeout = 900000;
var timer = setInterval(function()
{
   timeout -= 1000;
   document.getElementById('countDown').innerHTML = time(timeout);  
   if (timeout == 0)
   {
      clearInterval(timer);
      alert('Your Session Has Expired!')
      var LoginPage ="http://192.168.165.22:85"      // Publish
      //var LoginPage ="http://"+ document.location.host + "/LeaveManagementSystem/LoginLMS.aspx"      // Local
      

      
      document.getElementById('countDown').innerHTML = 'Your Session Has Expired!'
      javascript:window.location.href =LoginPage ;
     
   }
}
, 1000);

function two(x)
{

   return ((x > 9) ? "" : "0") + x
}

function time(ms)
{
   var t = '';
   var sec = Math.floor(ms / 1000);
   ms = ms % 1000

   var min = Math.floor(sec / 60);
   sec = sec % 60;
  

   var hr = Math.floor(min / 60);
   min = min % 60;
   t = hr + ":" + two(min) + ":" + two(sec);


   return "Your Session Will TimeOut In " + t ;
}
    </script>

</head>
<body>
    <form id="form1" runat="server">
        <div id="aaaaa" style="border-right: #009900 3px groove; padding-right: 3px; border-top: #009900 3px groove;
            padding-left: 3px; padding-bottom: 3px; border-left: #009900 3px groove; padding-top: 3px;
            border-bottom: #009900 3px groove">
            <div style="padding: 5px">
                <table cellpadding="0" cellspacing="5" style="width: 100%">
                    <tr>
                        <td style="width: 100%; border: #000099 3px solid; padding: 5px; height: 80px">
